{
  "name": "piggytrans",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "icon": "python3 scripts/prepare-icon.py && tauri icon app-icon.png -o src-tauri/icons",
    "package:mac-arm": "tauri build --target aarch64-apple-darwin",
    "package:mac-intel": "tauri build --target x86_64-apple-darwin",
    "package:win": "tauri build"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.2.7",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "~5.7.2",
    "vite": "^6.0.11"
  }
}
